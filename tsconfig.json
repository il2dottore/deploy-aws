{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "types": [
      "node",
      "jest",
      "express"
    ],
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@app/common": [
        "./libs/common/src"
      ],
      "@app/common/*": [
        "./libs/common/src/*"
      ],
      "@app/config": [
        "./libs/config/src"
      ],
      "@app/config/*": [
        "./libs/config/src/*"
      ],
      "@app/database": [
        "./libs/database/src"
      ],
      "@app/database/*": [
        "./libs/database/src/*"
      ],
      "@app/redis": [
        "./libs/redis/src"
      ],
      "@app/redis/*": [
        "./libs/redis/src/*"
      ],
      "@app/auth": [
        "./libs/auth/src"
      ],
      "@app/auth/*": [
        "./libs/auth/src/*"
      ],
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "infra"
  ],
}