# Service listening ports
AUTH_SERVICE_PORT=3001
UPLOAD_SERVICE_PORT=3002
NODE_ENV=production

# JWT secret credentials
JWT_ACCESS_SECRET='This-Is-A-Very-Secret-String'
JWT_ACCESS_EXPIRES_IN='15m'
JWT_REFRESH_SECRET='This-Is-A-Very-Secret-String'
JWT_REFRESH_EXPIRES_IN='7d'

# RDS credentials
DATABASE_HOST='postgres'
DATABASE_PORT=5432
DATABASE_USER='postgres'
DATABASE_PASS='postgres'

# Redis credentials
REDIS_HOST='redis'
REDIS_PORT=6379
REDIS_PASSWORD='redispass'

# Docker PostgreSQL credentials
POSTGRES_USER='postgres'
POSTGRES_PASSWORD='postgres'
POSTGRES_PORT=5432

# RabbitMQ credentials
RABBITMQ_DEFAULT_USER='rabbitmq'
RABBITMQ_DEFAULT_PASS='rabbitmq'
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_URL='amqp://rabbitmq:rabbitmq@rabbitmq:5672'

# S3 storage
S3_REGION='ap-southeast-1'
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
